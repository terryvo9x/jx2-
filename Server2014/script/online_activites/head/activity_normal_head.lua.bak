function VET_201102_Operating_SinhTo()
	AskClientForNumber("ConfirmSinhto", 1, 999, "Sinh tč trļi cĐy ?")
end

function ConfirmSinhto(nCount)
	if gf_Judge_Room_Weight(2, 100, "") ~= 1 then
        return 0;
    end
   if GetItemCount(2,1,30317) < (5 * nCount ) or GetItemCount(2,1,30230) < (2 * nCount)  then
        Talk(1, "", "Bđn khŦng Ūņ ŪiŌu kiÖn Ūæi "..nCount.." Sinh tč trļi cĐy");
        return 0;
   elseif  DelItem(2,1,30317, 5 * nCount)and DelItem(2,1,30230,  2 * nCount) == 1 then 
        gf_AddItemEx2({2,1,30319, nCount}, "Sinh tč trļi cĐy", EVENT_LOG_TITLE, "Ūæi vËt phČm bŧng xu", 0, 1)
    end
    SelectSay()
end