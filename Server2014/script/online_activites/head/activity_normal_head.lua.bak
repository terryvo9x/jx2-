function gf_VnGetPrizeRandomSeed(tbPrize)
	local nRandomSeed = 0
	for i = 1,getn(tbPrize) do
		nRandomSeed = nRandomSeed + tbPrize[i][2]
	end
	return nRandomSeed
end
