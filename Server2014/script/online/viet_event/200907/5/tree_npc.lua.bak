function main()
	local nPlantTimePassed = 0;
	local nWaterTimePassed = 0;
	local npcIdx, npcModel, npcName = GetTriggeringUnit();--ĽŮĶ√ĶĪ«įī•∑Ę∆ųņÔĶńNPCňų“ż£¨ń£įŚID£¨Ō‘ ĺ√Ż◊÷
	if npcIdx == 0 then
		WriteLog("[Hoat dong trong cay thang 8 loi]:"..GetName().."Trong lůc t≠Ūi c©y, GetTriggeringUnit thÝ nh t sŌ trŽ v“ 0");
		return 0;
	end
	local nNameLen = strlen(GetName());
	local bJudgeByName = 0;
	if GetName() == strsub(npcName, 1, nNameLen) then --”√√Ż◊÷ņīŇ–∂Ō «≤Ľ «Õśľ“Ķń ų
		bJudgeByName = 1;
	end
	local bIsTree = 0;
	for i = 1, getn(TREE_TYPE) do
		if npcModel == TREE_TYPE[i][1] then
			bIsTree = 1;
			break;
		end
	end
	if bIsTree == 0 then
		SetNpcScript(npcIdx, "");
		WriteLog("[Hoat dong trong cay thang 8 loi] NPC:"..npcName.."LÁi files gŤc");
		return 0;
	end
	local npcTreeIndex = GetTargetNpc(); --ĽŮ»°Õśľ“Ķń∂Į◊ų∂‘ŌůNpc
	if npcTreeIndex == 0 then
		WriteLog("[Hoat dong trong cay thang 8 loi]:"..GetName.."Khi t≠Ūi n≠Ūc, GetTargetNpc trř quay lĻi lĶ 0");
		return 0;
	end;
	if bJudgeByName == 0 then
		Msg2Player("ß©y khęng ph∂i lĶ c©y bĻn trŚng");
		return 0;
	end
	if npcTreeIndex ~= GetTask(TASK_TREE_INDEX) then
		Msg2Player("ß©y khęng ph∂i lĶ c©y bĻn trŚng");
		return 0;
	end
	
	local nTreeGrow = GetTask(TASK_TREE_GROW);
	nPlantTimePassed = GetTime() - GetTask(TASK_PLANT_TREE_TIME);
	nWaterTimePassed = GetTime() - GetTask(TASK_WATER_TREE_TIME);
	
	local sSysSth = "";
	local selTab = {};
	--»ÁĻŻ «≤Ľňņ ų
	if GetTask(TASK_PLANT_TREE_TYPE) == 2 then
		if nPlantTimePassed < 240 then
			Talk(1, "", "C©y B t TŲ v…n ch≠a tr≠Íng thĶnh, b©y giÍ khęng th” thu hoĻch ģ≠Óc, ģÓi <color=yellow>" .. 240 - nPlantTimePassed .. " gi©y<color> h∑y ti’p tŰc thu hoĻch");
			return 0;
		else
			tinsert(selTab, "B©y giÍ thu hoĻch /getTree");
			tinsert(selTab, "ßÓi mťt lůc h∑y thu hoĻch ti’p/nothing");
			sSaySth = "C©y ģ∑ tr≠Žng thĶnh, muŤn thu hoĻch b©y giÍ? N’u nh≠<color=yellow>" .. 300 - nPlantTimePassed .. "<color> gi©y sau khęng thu hoĻch, c©y sŌ tý ģťng ch’t ģi";
		end
	else
		if nTreeGrow == 1 then
			if nPlantTimePassed	< TREE_PARAM[nTreeGrow][3] then
				Talk(1, "", "C«n ph∂i ģÓi th™m <color=yellow>"
						 .. TREE_PARAM[nTreeGrow][3] - nPlantTimePassed ..
						 "<color> gi©y mŪi c„ th” t≠Ūi n≠Ūc, c„ ģi“u ģűng c„ chĻy ģi quł xa, n’u nh≠ <color=yellow>"
						 .. TREE_PARAM[nTreeGrow][2] - nPlantTimePassed .. 
						 "<color> gi©y sau khęng t≠Ūi n≠Ūc, c©y thi’u n≠Ūc sŌ ch’t ģi."
				);	
				return 0;
			end
		end
		if nTreeGrow < 6 and nTreeGrow ~= 1 then
			if nPlantTimePassed > TREE_PARAM[nTreeGrow - 1][3] and nPlantTimePassed	<= TREE_PARAM[nTreeGrow][3] then
				Talk(1, "", "C«n ph∂i ģÓi th™m <color=yellow>"
						 .. TREE_PARAM[nTreeGrow][3] - nPlantTimePassed ..
						 "<color> gi©y mŪi c„ th” t≠Ūi n≠Ūc, c„ ģi“u ģűng c„ chĻy ģi quł xa, n’u nh≠ <color=yellow>"
						 .. TREE_PARAM[nTreeGrow][2] - nPlantTimePassed .. 
						 "<color> gi©y sau khęng t≠Ūi n≠Ūc, c©y thi’u n≠Ūc sŌ ch’t ģi."
				);	
				return 0;
			end
		end
		if nTreeGrow == 6 then
			if nPlantTimePassed < TREE_PARAM[nTreeGrow][3] then
				Talk(1, "", TREE_TYPE[GetTask(TASK_PLANT_TREE_TYPE)][2] .. "V…n ch≠a tr≠Žng thĶnh, n™n khęng th” thu hoĻch b©y giÍ ģ≠Óc<color=yellow>" ..TREE_PARAM[nTreeGrow][3] - nPlantTimePassed .. " gi©y<color> h∑y ti’p tŰc thu hoĻch");
				return 0;
			end
			tinsert(selTab, "B©y giÍ thu hoĻch /getTree");
			tinsert(selTab, "ßÓi mťt lůc h∑y thu hoĻch ti’p/nothing");
			sSaySth = "C©y ģ∑ tr≠Žng thĶnh, muŤn thu hoĻch b©y giÍ? N’u nh≠<color=yellow>" .. getDateTimeString(TREE_PARAM[nTreeGrow][2] - nPlantTimePassed) .. "<color> gi©y sau khęng thu hoĻch, c©y sŌ tý ģťng ch’t ģi";
		else
				tinsert(selTab, "T≠Ūi n≠Ūc (c«n " .. TREE_PARAM[nTreeGrow + 1][4] .. " ph«n Lť ThŮy)/giveWater");
				tinsert(selTab, "Sau nĶy h∑y t≠Ūi./doNothing");
				sSaySth = TREE_TYPE[GetTask(TASK_PLANT_TREE_TYPE)][2] .. " ģang c«n t≠Ūi Lť ThŮy, c„ muŤn t≠Ūi khęng? N’u sau <color=yellow>" .. getDateTimeString(TREE_PARAM[nTreeGrow][2] - nPlantTimePassed) .. "<color> gi©y sau khęng t≠Ūi n≠Ūc, c©y thi’u n≠Ūc sŌ ch’t ģi.";
		end
	end
	
	Say(sSaySth, getn(selTab), selTab);
end

function nothing()
end

