-- Set global var
-- varName format: gf_FunctionName_passingValue
function gf_SetGlobalVar(varName, varValue)
    --define global var data
    if not g_GlobalVar then g_GlobalVar = {} end
    if not g_GlobalVar[GetName()] then g_GlobalVar[GetName()] = {} end
    if not g_GlobalVar[GetName()][varName] then g_GlobalVar[GetName()][varName] = nil end   
    g_GlobalVar[GetName()][varName] = varValue
    return g_GlobalVar[GetName()][varName]
end

-- Get global var by varName
function gf_GetGlobalVar(varName)
    --catch global var data
    if not g_GlobalVar then return nil end
    if not g_GlobalVar[GetName()] then return nil end
    if not g_GlobalVar[GetName()][varName] then return nil end
    return g_GlobalVar[GetName()][varName]
end
